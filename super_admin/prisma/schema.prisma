// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// BLOG & ARTICLE CMS MODELS
// ============================================

// Blog Authors
model BlogAuthor {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  title           String?  // Job title
  bio             String?
  photoUrl        String?
  email           String?
  linkedinUrl     String?
  twitterHandle   String?
  expertise       String?  // JSON array of topics
  credentials     String?  // JSON array of degrees/certifications
  yearsExperience Int?
  role            String   @default("author") // super_admin, editor, author, contributor, reviewer
  isActive        Boolean  @default(true)
  postCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           BlogPost[]
}

// Blog Categories (Hierarchical)
model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  imageUrl    String?
  seoTitle    String?
  seoDesc     String?
  sortOrder   Int      @default(0)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      BlogCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    BlogCategory[] @relation("CategoryHierarchy")
  posts       BlogPostCategory[]
}

// Blog Tags
model BlogTag {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       BlogPostTag[]
}

// Blog Posts
model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String?   // JSON block editor content
  contentHtml     String?   // Rendered HTML (cached)
  contentText     String?   // Plain text (for search)
  excerpt         String?   // Auto or manual excerpt

  // Media
  featuredImageUrl String?
  featuredImageAlt String?
  coverImageUrl   String?

  // Classification
  contentType     String    @default("blog") // blog, article, tutorial, news, case-study, press-release
  status          String    @default("draft") // draft, review, scheduled, published, unpublished, archived
  visibility      String    @default("public") // public, private, password
  password        String?

  // Author
  authorId        String
  author          BlogAuthor @relation(fields: [authorId], references: [id])

  // SEO
  seoTitle        String?
  seoDescription  String?
  focusKeyword    String?
  secondaryKeywords String? // JSON array
  canonicalUrl    String?
  robotsIndex     Boolean   @default(true)
  robotsFollow    Boolean   @default(true)
  schemaType      String    @default("BlogPosting")
  sitemapPriority Float     @default(0.8)
  sitemapChangefreq String  @default("weekly")

  // Social
  ogTitle         String?
  ogDescription   String?
  ogImageUrl      String?
  twitterCard     String    @default("summary_large_image")

  // Stats
  viewCount       Int       @default(0)
  shareCount      Int       @default(0)
  commentCount    Int       @default(0)
  readingTimeMin  Int?
  wordCount       Int?

  // Settings
  allowComments   Boolean   @default(true)
  isFeatured      Boolean   @default(false)

  // Dates
  publishedAt     DateTime?
  scheduledAt     DateTime?
  unpublishAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  categories      BlogPostCategory[]
  tags            BlogPostTag[]
  comments        BlogComment[]
  revisions       BlogRevision[]
}

// Post-Category Many-to-Many
model BlogPostCategory {
  postId     String
  categoryId String

  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

// Post-Tag Many-to-Many
model BlogPostTag {
  postId String
  tagId  String

  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// Blog Comments
model BlogComment {
  id          String   @id @default(cuid())
  postId      String
  parentId    String?
  authorName  String
  authorEmail String
  authorUrl   String?
  content     String
  status      String   @default("pending") // pending, approved, spam, trash
  ipAddress   String?
  userAgent   String?
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent      BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     BlogComment[] @relation("CommentReplies")
}

// Media Library
model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int?
  width        Int?
  height       Int?
  s3Key        String?
  cdnUrl       String?
  altText      String?
  caption      String?
  folder       String   @default("/")
  uploadedBy   String?
  sizes        String?  // JSON object with thumbnail, medium, large URLs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Post Revisions
model BlogRevision {
  id        String   @id @default(cuid())
  postId    String
  content   String?  // JSON
  title     String?
  revisedBy String?
  createdAt DateTime @default(now())

  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// Blog Settings
model BlogSetting {
  key       String   @id
  value     String?  // JSON
  updatedAt DateTime @updatedAt
}

// Blog Indexing Log
model BlogIndexingLog {
  id        String   @id @default(cuid())
  postId    String?
  url       String
  service   String   // google, indexnow, bing
  status    String?  // success, failed
  response  String?  // JSON
  createdAt DateTime @default(now())
}