// ============================================================
// EduHub — Prisma Schema
// Database: PostgreSQL 16 (AWS RDS Aurora)
// PRD Reference: Section 10 — Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ORG_STAFF
  STUDENT
}

enum StaffRole {
  ORG_ADMIN
  TEACHER
  CONTENT_MANAGER
  FEE_MANAGER
  RECEPTIONIST
  ANALYTICS_VIEWER
}

enum OrgPlan {
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  TRUE_FALSE
  FILL_IN_BLANK
  DESCRIPTIVE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MasteryLevel {
  UNATTEMPTED
  WEAK
  DEVELOPING
  PROFICIENT
  MASTERED
}

enum TestStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  TIMED_OUT
}

enum PracticeSetStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum NotificationChannel {
  APP_PUSH
  WHATSAPP
  SMS
  EMAIL
}

enum PaymentMethod {
  CASH
  UPI
  CHEQUE
  BANK_TRANSFER
  RAZORPAY
}

enum FeeStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum FolderScope {
  GLOBAL
  ORG
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  mobile       String?   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  superAdmin   SuperAdmin?
  orgStaff     OrgStaff?
  student      Student?

  @@map("users")
}

model SuperAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("super_admins")
}

// ============================================================
// ORGANIZATIONS
// ============================================================

model Organization {
  id             String       @id @default(cuid())
  orgId          String       @unique // GK-ORG-XXXXX
  name           String
  category       String?      // coaching, school, university
  email          String?
  mobile         String?
  address        String?
  city           String?
  state          String?
  logoUrl        String?
  primaryColor   String?      @default("#6366f1")
  subdomain      String?      @unique
  customDomain   String?      @unique
  plan           OrgPlan      @default(SMALL)
  billingCycle   BillingCycle @default(MONTHLY)
  status         OrgStatus    @default(TRIAL)
  trialEndsAt    DateTime?
  planStartedAt  DateTime?
  planExpiresAt  DateTime?
  aiCredits      Float        @default(500)
  aiCreditsUsed  Float        @default(0)
  studentCount   Int          @default(0)
  staffCount     Int          @default(0)
  storageUsedGB  Float        @default(0)
  orgAdminEmail  String?
  orgAdminPassword String?    // hashed — for org admin login
  receiptCounter Int          @default(0)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  staff           OrgStaff[]
  students        Student[]
  batches         Batch[]
  qbankFolders    QBankFolder[]
  questions       Question[]
  questionSets    QuestionSet[]
  mockTests       MockTest[]
  attendance      AttendanceRecord[]
  feeStructures   FeeStructure[]
  feeTransactions FeeTransaction[]
  notifications   OrgNotification[]
  featureFlags    OrgFeatureFlag[]
  aiTransactions  AiCreditTransaction[]
  auditLogs       OrgAuditLog[]
  personalizationSettings OrgPersonalizationSettings?
  curatedSuggestions      AdminCuratedSuggestion[]
  studyPlanTemplates      StudyPlanTemplate[]
  autoSetConfigs          AutoSetConfig[]

  @@map("organizations")
}

model OrgFeatureFlag {
  id     String @id @default(uuid())
  orgId  String
  key    String // ai_question_generation, pdf_extraction, etc.
  value  Boolean @default(false)

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, key])
  @@map("org_feature_flags")
}

// ============================================================
// STAFF
// ============================================================

model OrgStaff {
  id          String    @id @default(uuid())
  staffId     String    @unique // GK-TCH-XXXXX or GK-STF-XXXXX
  userId      String    @unique
  orgId       String
  name        String
  email       String?
  mobile      String?
  role        StaffRole @default(TEACHER)
  permissions String[]  @default([]) // custom overrides
  photoUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  attendanceMarked AttendanceRecord[] @relation("MarkedByStaff")

  @@map("org_staff")
}

// ============================================================
// STUDENTS
// ============================================================

model Student {
  id              String    @id @default(uuid())
  studentId       String    @unique // GK-STU-XXXXX
  userId          String    @unique
  orgId           String
  name            String
  email           String?
  mobile          String?
  parentMobile    String?
  photoUrl        String?
  dateOfBirth     DateTime?
  address         String?
  isActive        Boolean   @default(true)
  enrolledAt      DateTime  @default(now())
  testsCompleted  Int       @default(0)
  personalizationUnlocked Boolean @default(false)
  personalizationUnlockedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  batchEnrollments  BatchStudent[]
  attendance        AttendanceRecord[]
  feeTransactions   FeeTransaction[]
  testAttempts      TestAttempt[]
  questionHistory   StudentQuestionHistory[]
  topicMastery      StudentTopicMastery[]
  personalizationStatus StudentPersonalizationStatus?
  practiceSets      StudentPracticeSet[]
  studyPlan         StudentStudyPlan?

  @@map("students")
}

// ============================================================
// BATCHES
// ============================================================

model Batch {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Organization  @relation(fields: [orgId], references: [id])
  students BatchStudent[]
  tests    MockTestBatch[]

  @@map("batches")
}

model BatchStudent {
  id        String   @id @default(uuid())
  batchId   String
  studentId String
  joinedAt  DateTime @default(now())

  batch   Batch   @relation(fields: [batchId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([batchId, studentId])
  @@map("batch_students")
}

// ============================================================
// CONTENT HIERARCHY
// ============================================================

model Subject {
  id        String    @id @default(uuid())
  orgId     String?   // null = global
  name      String
  createdAt DateTime  @default(now())

  chapters Chapter[]

  @@map("subjects")
}

model Chapter {
  id        String   @id @default(uuid())
  subjectId String
  orgId     String?
  name      String
  createdAt DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id])
  topics  Topic[]

  @@map("chapters")
}

model Topic {
  id        String   @id @default(uuid())
  chapterId String
  orgId     String?
  name      String
  createdAt DateTime @default(now())

  chapter        Chapter               @relation(fields: [chapterId], references: [id])
  questions      Question[]
  topicMastery   StudentTopicMastery[]

  @@map("topics")
}

// ============================================================
// Q-BANK FOLDER SYSTEM (Unlimited nesting, materialized path)
// ============================================================

model QBankFolder {
  id                 String      @id @default(uuid())
  orgId              String?     // null = global folder
  name               String
  parentId           String?
  path               String      // materialized path: /parentId/childId
  depth              Int         @default(0)
  scope              FolderScope @default(ORG)
  questionCount      Int         @default(0)
  totalQuestionCount Int         @default(0)
  sortOrder          Int         @default(0)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  org      Organization? @relation(fields: [orgId], references: [id])
  parent   QBankFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children QBankFolder[] @relation("FolderTree")
  questions Question[]

  @@index([path])
  @@index([orgId])
  @@map("qbank_folders")
}

// ============================================================
// QUESTIONS
// ============================================================

model Question {
  id              String       @id @default(uuid())
  questionId      String       @unique // GK-Q-XXXXXXX
  orgId           String?      // null = global question
  folderId        String?
  topicId         String?
  type            QuestionType @default(MCQ_SINGLE)
  difficulty      Difficulty   @default(MEDIUM)
  textEn          String?      // English text
  textHi          String?      // Hindi text
  explanationEn   String?
  explanationHi   String?
  imageUrl        String?
  tags            String[]     @default([])
  isGlobal        Boolean      @default(false)
  isApproved      Boolean      @default(false)
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  org     Organization? @relation(fields: [orgId], references: [id])
  folder  QBankFolder?  @relation(fields: [folderId], references: [id])
  topic   Topic?        @relation(fields: [topicId], references: [id])
  options QuestionOption[]
  setItems QuestionSetItem[]
  questionHistory StudentQuestionHistory[]

  @@index([orgId])
  @@index([folderId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  textEn     String?
  textHi     String?
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

// ============================================================
// QUESTION SETS
// ============================================================

model QuestionSet {
  id          String   @id @default(uuid())
  setId       String   @unique // 6-digit numeric
  pin         String   // 6-digit numeric (different from setId)
  orgId       String
  name        String
  description String?
  totalQuestions Int   @default(0)
  durationMins   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org   Organization    @relation(fields: [orgId], references: [id])
  items QuestionSetItem[]
  testSections MockTestSection[]

  @@map("question_sets")
}

model QuestionSetItem {
  id         String @id @default(uuid())
  setId      String
  questionId String
  sortOrder  Int    @default(0)
  marksCorrect   Float @default(1)
  marksNegative  Float @default(0)

  set      QuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([setId, questionId])
  @@map("question_set_items")
}

// ============================================================
// TESTS & EXAMS
// ============================================================

model MockTest {
  id            String     @id @default(uuid())
  testId        String     @unique // 6-digit
  pin           String     // 6-digit
  orgId         String
  name          String
  description   String?
  status        TestStatus @default(DRAFT)
  durationMins  Int
  totalMarks    Float      @default(0)
  passingMarks  Float?
  shuffleQuestions Boolean @default(false)
  showResult    Boolean    @default(true)
  maxAttempts   Int        @default(1)
  isPublic      Boolean    @default(false) // MockVeda public
  scheduledAt   DateTime?
  endsAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  org      Organization     @relation(fields: [orgId], references: [id])
  sections MockTestSection[]
  batches  MockTestBatch[]
  attempts TestAttempt[]

  @@map("mock_tests")
}

model MockTestSection {
  id          String @id @default(uuid())
  testId      String
  setId       String
  name        String
  sortOrder   Int    @default(0)
  durationMins Int?

  test MockTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  set  QuestionSet @relation(fields: [setId], references: [id])

  @@map("mock_test_sections")
}

model MockTestBatch {
  id      String @id @default(uuid())
  testId  String
  batchId String

  test  MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  batch Batch    @relation(fields: [batchId], references: [id])

  @@unique([testId, batchId])
  @@map("mock_test_batches")
}

model TestAttempt {
  id          String        @id @default(uuid())
  testId      String
  studentId   String
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  score       Float?
  totalMarks  Float?
  rank        Int?
  percentile  Float?
  timeTakenSecs Int?
  createdAt   DateTime      @default(now())

  test    MockTest  @relation(fields: [testId], references: [id])
  student Student   @relation(fields: [studentId], references: [id])
  answers AttemptAnswer[]

  @@map("test_attempts")
}

model AttemptAnswer {
  id          String  @id @default(uuid())
  attemptId   String
  questionId  String
  selectedOptions String[] @default([])
  isCorrect   Boolean?
  marksAwarded Float?
  timeTakenSecs Int?

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("attempt_answers")
}

// ============================================================
// STUDENT INTELLIGENCE — Question History & Mastery
// ============================================================

model StudentQuestionHistory {
  id            String       @id @default(uuid())
  studentId     String
  questionId    String
  orgId         String
  attemptCount  Int          @default(0)
  correctCount  Int          @default(0)
  wrongCount    Int          @default(0)
  skipCount     Int          @default(0)
  avgTimeSecs   Float        @default(0)
  lastResult    String?      // correct | wrong | skipped
  masteryScore  Float        @default(0) // 0-100
  masteryLevel  MasteryLevel @default(UNATTEMPTED)
  lastAttemptAt DateTime?
  updatedAt     DateTime     @updatedAt

  student  Student  @relation(fields: [studentId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([studentId, questionId])
  @@index([studentId])
  @@map("student_question_history")
}

model StudentTopicMastery {
  id          String       @id @default(uuid())
  studentId   String
  topicId     String
  orgId       String
  avgMastery  Float        @default(0)
  isWeak      Boolean      @default(false)
  updatedAt   DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  topic   Topic   @relation(fields: [topicId], references: [id])

  @@unique([studentId, topicId])
  @@map("student_topic_mastery")
}

model StudentPersonalizationStatus {
  id              String   @id @default(uuid())
  studentId       String   @unique
  orgId           String
  isUnlocked      Boolean  @default(false)
  unlockedAt      DateTime?
  streakDays      Int      @default(0)
  lastStreakDate  DateTime?
  totalPracticeCompleted Int @default(0)

  student Student @relation(fields: [studentId], references: [id])

  @@map("student_personalization_status")
}

model StudentPracticeSet {
  id          String            @id @default(uuid())
  studentId   String
  orgId       String
  name        String
  status      PracticeSetStatus @default(PENDING)
  questionIds String[]
  config      Json?
  expiresAt   DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@map("student_practice_sets")
}

model StudentStudyPlan {
  id            String   @id @default(uuid())
  studentId     String   @unique
  orgId         String
  dailyMins     Int
  durationDays  Int
  examDate      DateTime?
  startDate     DateTime @default(now())
  endDate       DateTime?
  planData      Json     // subject priorities, daily focus topics
  isActive      Boolean  @default(true)
  adherencePct  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student              @relation(fields: [studentId], references: [id])
  dailyProgress StudyPlanDailyProgress[]

  @@map("student_study_plans")
}

model StudyPlanDailyProgress {
  id          String   @id @default(uuid())
  planId      String
  date        DateTime
  targetQs    Int
  completedQs Int      @default(0)
  isPassed    Boolean  @default(false) // >= 80% = streak counted

  plan StudentStudyPlan @relation(fields: [planId], references: [id])

  @@unique([planId, date])
  @@map("study_plan_daily_progress")
}

// ============================================================
// PDF EXTRACTION
// ============================================================

model ExtractFolder {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  documents ExtractDocument[]

  @@map("extract_folders")
}

model ExtractDocument {
  id          String   @id @default(uuid())
  orgId       String
  folderId    String?
  fileName    String
  s3Key       String
  status      String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  totalExtracted Int   @default(0)
  creditsUsed Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folder    ExtractFolder?    @relation(fields: [folderId], references: [id])
  questions ExtractedQuestion[]

  @@map("extract_documents")
}

model ExtractedQuestion {
  id         String   @id @default(uuid())
  documentId String
  orgId      String
  textEn     String?
  textHi     String?
  options    Json?
  isCopied   Boolean  @default(false) // copied to main Q-Bank?
  createdAt  DateTime @default(now())

  document ExtractDocument @relation(fields: [documentId], references: [id])

  @@map("extracted_questions")
}

// ============================================================
// ATTENDANCE
// ============================================================

model AttendanceRecord {
  id          String   @id @default(uuid())
  orgId       String
  studentId   String
  batchId     String?
  date        DateTime @db.Date
  isPresent   Boolean
  markedById  String?  // staff who marked
  lockedAt    DateTime? // 24-hour edit window
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id])
  student Student      @relation(fields: [studentId], references: [id])
  markedBy OrgStaff?  @relation("MarkedByStaff", fields: [markedById], references: [id])

  @@unique([studentId, date, batchId])
  @@map("attendance_records")
}

// ============================================================
// FEES
// ============================================================

model FeeStructure {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  amount      Float
  dueDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  org          Organization    @relation(fields: [orgId], references: [id])
  transactions FeeTransaction[]

  @@map("fee_structures")
}

model FeeTransaction {
  id            String        @id @default(uuid())
  orgId         String
  studentId     String
  feeStructureId String?
  amount        Float
  status        FeeStatus     @default(PENDING)
  paymentMethod PaymentMethod?
  receiptNumber String?       // 2026-00458 format
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  org          Organization @relation(fields: [orgId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id])

  @@map("fee_transactions")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model OrgNotification {
  id          String              @id @default(uuid())
  orgId       String
  title       String
  body        String
  channel     NotificationChannel
  targetType  String              // ALL | BATCH | STUDENT | STAFF
  targetIds   String[]            @default([])
  scheduledAt DateTime?
  sentAt      DateTime?
  deliveredCount Int              @default(0)
  failedCount    Int              @default(0)
  createdAt   DateTime            @default(now())

  org  Organization      @relation(fields: [orgId], references: [id])
  logs NotificationLog[]

  @@map("org_notifications")
}

model NotificationLog {
  id             String   @id @default(uuid())
  notificationId String
  recipientId    String
  recipientType  String   // student | staff
  isDelivered    Boolean  @default(false)
  failureReason  String?
  createdAt      DateTime @default(now())

  notification OrgNotification @relation(fields: [notificationId], references: [id])

  @@map("notification_logs")
}

// ============================================================
// PERSONALIZATION ADMIN CONTROLS
// ============================================================

model OrgPersonalizationSettings {
  id                String   @id @default(uuid())
  orgId             String   @unique
  isEnabled         Boolean  @default(true)
  unlockThreshold   Int      @default(50)
  aiMatchEnabled    Boolean  @default(true)
  collabFilterEnabled Boolean @default(false)
  studyPlanEnabled  Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@map("org_personalization_settings")
}

model AdminCuratedSuggestion {
  id              String   @id @default(uuid())
  orgId           String
  topicKeywords   String[]
  setId           String?
  folderId        String?
  title           String
  priority        Int      @default(0)
  expectedImprovement Float?
  impressions     Int      @default(0)
  attempts        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@map("admin_curated_suggestions")
}

model StudyPlanTemplate {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  durationDays Int
  templateData Json    // daily schedule, subject allocation
  usageCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@map("study_plan_templates")
}

model AutoSetConfig {
  id         String   @id @default(uuid())
  orgId      String
  name       String
  configData Json     // full 5-step config
  schedules  Json?    // cron schedule config
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@map("auto_set_configs")
}

// ============================================================
// AUDIT
// ============================================================

model AiCreditTransaction {
  id          String   @id @default(uuid())
  orgId       String
  action      String   // pdf_extraction, ai_generate, auto_set_smart
  credits     Float
  description String?
  createdAt   DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@map("ai_credit_transactions")
}

model OrgAuditLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String
  actorType String   // super_admin | org_staff
  action    String
  resource  String?
  changes   Json?
  ip        String?
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@map("org_audit_logs")
}
