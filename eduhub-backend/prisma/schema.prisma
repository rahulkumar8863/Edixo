generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String?     @unique
  mobile       String?     @unique
  passwordHash String
  role         UserRole
  isActive     Boolean     @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orgStaff     OrgStaff?
  student      Student?
  superAdmin   SuperAdmin?

  @@map("users")
}

model SuperAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("super_admins")
}

model Organization {
  id                      String                      @id @default(cuid())
  orgId                   String                      @unique
  name                    String
  category                String?
  email                   String?
  mobile                  String?
  address                 String?
  city                    String?
  state                   String?
  logoUrl                 String?
  primaryColor            String?                     @default("#6366f1")
  subdomain               String?                     @unique
  customDomain            String?                     @unique
  plan                    OrgPlan                     @default(SMALL)
  billingCycle            BillingCycle                @default(MONTHLY)
  status                  OrgStatus                   @default(TRIAL)
  trialEndsAt             DateTime?
  planStartedAt           DateTime?
  planExpiresAt           DateTime?
  aiCredits               Float                       @default(500)
  aiCreditsUsed           Float                       @default(0)
  studentCount            Int                         @default(0)
  staffCount              Int                         @default(0)
  storageUsedGB           Float                       @default(0)
  orgAdminEmail           String?
  orgAdminPassword        String?
  receiptCounter          Int                         @default(0)
  deletedAt               DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  curatedSuggestions      AdminCuratedSuggestion[]
  aiTransactions          AiCreditTransaction[]
  attendance              AttendanceRecord[]
  autoSetConfigs          AutoSetConfig[]
  batches                 Batch[]
  bulkUploadBatches       BulkUploadBatch[]
  feeStructures           FeeStructure[]
  feeTransactions         FeeTransaction[]
  mockTests               MockTest[]
  auditLogs               OrgAuditLog[]
  featureFlags            OrgFeatureFlag[]
  notifications           OrgNotification[]
  personalizationSettings OrgPersonalizationSettings?
  staff                   OrgStaff[]
  qbankFolders            QBankFolder[]
  questionSets            QuestionSet[]
  questions               Question[]
  students                Student[]
  studyPlanTemplates      StudyPlanTemplate[]

  @@map("organizations")
}

model OrgFeatureFlag {
  id    String       @id @default(uuid())
  orgId String
  key   String
  value Boolean      @default(false)
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, key])
  @@map("org_feature_flags")
}

model OrgStaff {
  id               String             @id @default(uuid())
  staffId          String             @unique
  userId           String             @unique
  orgId            String
  name             String
  email            String?
  mobile           String?
  role             StaffRole          @default(TEACHER)
  permissions      String[]           @default([])
  photoUrl         String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  attendanceMarked AttendanceRecord[] @relation("MarkedByStaff")
  org              Organization       @relation(fields: [orgId], references: [id])
  user             User               @relation(fields: [userId], references: [id])

  @@map("org_staff")
}

model Student {
  id                        String                        @id @default(uuid())
  studentId                 String                        @unique
  userId                    String                        @unique
  orgId                     String
  name                      String
  email                     String?
  mobile                    String?
  parentMobile              String?
  photoUrl                  String?
  dateOfBirth               DateTime?
  address                   String?
  isActive                  Boolean                       @default(true)
  enrolledAt                DateTime                      @default(now())
  testsCompleted            Int                           @default(0)
  personalizationUnlocked   Boolean                       @default(false)
  personalizationUnlockedAt DateTime?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  attendance                AttendanceRecord[]
  batchEnrollments          BatchStudent[]
  feeTransactions           FeeTransaction[]
  personalizationStatus     StudentPersonalizationStatus?
  practiceSets              StudentPracticeSet[]
  questionHistory           StudentQuestionHistory[]
  studyPlan                 StudentStudyPlan?
  topicMastery              StudentTopicMastery[]
  org                       Organization                  @relation(fields: [orgId], references: [id])
  user                      User                          @relation(fields: [userId], references: [id])
  testAttempts              TestAttempt[]

  @@map("students")
}

model Batch {
  id          String          @id @default(uuid())
  orgId       String
  name        String
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  students    BatchStudent[]
  org         Organization    @relation(fields: [orgId], references: [id])
  tests       MockTestBatch[]

  @@map("batches")
}

model BatchStudent {
  id        String   @id @default(uuid())
  batchId   String
  studentId String
  joinedAt  DateTime @default(now())
  batch     Batch    @relation(fields: [batchId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([batchId, studentId])
  @@map("batch_students")
}

model Subject {
  id        String    @id @default(uuid())
  orgId     String?
  name      String
  createdAt DateTime  @default(now())
  chapters  Chapter[]

  @@map("subjects")
}

model Chapter {
  id        String   @id @default(uuid())
  subjectId String
  orgId     String?
  name      String
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id])
  topics    Topic[]

  @@map("chapters")
}

model Topic {
  id           String                @id @default(uuid())
  chapterId    String
  orgId        String?
  name         String
  createdAt    DateTime              @default(now())
  questions    Question[]
  topicMastery StudentTopicMastery[]
  chapter      Chapter               @relation(fields: [chapterId], references: [id])

  @@map("topics")
}

model QBankFolder {
  id                 String        @id @default(uuid())
  orgId              String?
  name               String
  parentId           String?
  path               String
  depth              Int           @default(0)
  scope              FolderScope   @default(ORG)
  questionCount      Int           @default(0)
  totalQuestionCount Int           @default(0)
  sortOrder          Int           @default(0)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  org                Organization? @relation(fields: [orgId], references: [id])
  parent             QBankFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children           QBankFolder[] @relation("FolderTree")
  questions          Question[]

  @@index([path])
  @@index([orgId])
  @@map("qbank_folders")
}

model Question {
  id              String                   @id @default(uuid())
  questionId      String                   @unique
  orgId           String?
  folderId        String?
  topicId         String?
  type            QuestionType             @default(MCQ_SINGLE)
  difficulty      Difficulty               @default(MEDIUM)
  textEn          String?      // English text
  textHi          String?      // Hindi text
  explanationEn   String?
  explanationHi   String?
  imageUrl        String?
  tags            String[]                 @default([])
  isGlobal        Boolean                  @default(false)
  isApproved      Boolean                  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  // --- Extended Data (Airtable/Batch Sync) ---
  recordId          String?
  questionUniqueId  Int?         @unique
  subjectName       String?
  chapterName       String?
  collection        String?
  previousOf        String?
  exam              String?      @default("SSC CGL")
  year              Int?
  videoUrl          String?
  currentStatus     String?      @default("UPDATED")
  syncCode          Int?         @default(2)
  errorDescription  String?
  section           String?
  date              String?
  airtableTableName String?
  action            String?
  pointCost         Int          @default(10)
  usageCount        Int          @default(0)

  options         QuestionOption[]
  reports         QuestionReport[]
  setItems        QuestionSetItem[]
  folder          QBankFolder?             @relation(fields: [folderId], references: [id])
  org             Organization?            @relation(fields: [orgId], references: [id])
  topic           Topic?                   @relation(fields: [topicId], references: [id])
  questionHistory StudentQuestionHistory[]

  @@index([orgId])
  @@index([folderId])
  @@map("questions")
}

model QuestionReport {
  id           String       @id @default(uuid())
  questionId   String
  reporterId   String?
  reporterName String?
  reason       String?
  description  String?
  status       ReportStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  question     Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_reports")
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  textEn     String?
  textHi     String?
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model QuestionSet {
  id             String            @id @default(uuid())
  setId          String            @unique
  pin            String
  orgId          String
  name           String
  description    String?
  totalQuestions Int               @default(0)
  durationMins   Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  testSections   MockTestSection[]
  items          QuestionSetItem[]
  org            Organization      @relation(fields: [orgId], references: [id])

  @@map("question_sets")
}

model QuestionSetItem {
  id            String      @id @default(uuid())
  setId         String
  questionId    String
  sortOrder     Int         @default(0)
  marksCorrect  Float       @default(1)
  marksNegative Float       @default(0)
  question      Question    @relation(fields: [questionId], references: [id])
  set           QuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([setId, questionId])
  @@map("question_set_items")
}

model MockTest {
  id               String            @id @default(uuid())
  testId           String            @unique
  pin              String
  orgId            String
  name             String
  description      String?
  status           TestStatus        @default(DRAFT)
  durationMins     Int
  totalMarks       Float             @default(0)
  passingMarks     Float?
  shuffleQuestions Boolean           @default(false)
  showResult       Boolean           @default(true)
  maxAttempts      Int               @default(1)
  isPublic         Boolean           @default(false)
  scheduledAt      DateTime?
  endsAt           DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subCategoryId    String?
  batches          MockTestBatch[]
  sections         MockTestSection[]
  org              Organization      @relation(fields: [orgId], references: [id])
  subCategory      ExamSubCategory?  @relation(fields: [subCategoryId], references: [id])
  attempts         TestAttempt[]

  @@map("mock_tests")
}

model MockTestSection {
  id           String      @id @default(uuid())
  testId       String
  setId        String
  name         String
  sortOrder    Int         @default(0)
  durationMins Int?
  set          QuestionSet @relation(fields: [setId], references: [id])
  test         MockTest    @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("mock_test_sections")
}

model MockTestBatch {
  id      String   @id @default(uuid())
  testId  String
  batchId String
  batch   Batch    @relation(fields: [batchId], references: [id])
  test    MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, batchId])
  @@map("mock_test_batches")
}

model TestAttempt {
  id            String          @id @default(uuid())
  testId        String
  studentId     String
  status        AttemptStatus   @default(IN_PROGRESS)
  startedAt     DateTime        @default(now())
  submittedAt   DateTime?
  score         Float?
  totalMarks    Float?
  rank          Int?
  percentile    Float?
  timeTakenSecs Int?
  createdAt     DateTime        @default(now())
  answers       AttemptAnswer[]
  student       Student         @relation(fields: [studentId], references: [id])
  test          MockTest        @relation(fields: [testId], references: [id])

  @@map("test_attempts")
}

model AttemptAnswer {
  id              String      @id @default(uuid())
  attemptId       String
  questionId      String
  selectedOptions String[]    @default([])
  isCorrect       Boolean?
  marksAwarded    Float?
  timeTakenSecs   Int?
  attempt         TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("attempt_answers")
}

model StudentQuestionHistory {
  id            String       @id @default(uuid())
  studentId     String
  questionId    String
  orgId         String
  attemptCount  Int          @default(0)
  correctCount  Int          @default(0)
  wrongCount    Int          @default(0)
  skipCount     Int          @default(0)
  avgTimeSecs   Float        @default(0)
  lastResult    String?
  masteryScore  Float        @default(0)
  masteryLevel  MasteryLevel @default(UNATTEMPTED)
  lastAttemptAt DateTime?
  updatedAt     DateTime     @updatedAt
  question      Question     @relation(fields: [questionId], references: [id])
  student       Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, questionId])
  @@index([studentId])
  @@map("student_question_history")
}

model StudentTopicMastery {
  id         String   @id @default(uuid())
  studentId  String
  topicId    String
  orgId      String
  avgMastery Float    @default(0)
  isWeak     Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  student    Student  @relation(fields: [studentId], references: [id])
  topic      Topic    @relation(fields: [topicId], references: [id])

  @@unique([studentId, topicId])
  @@map("student_topic_mastery")
}

model StudentPersonalizationStatus {
  id                     String    @id @default(uuid())
  studentId              String    @unique
  orgId                  String
  isUnlocked             Boolean   @default(false)
  unlockedAt             DateTime?
  streakDays             Int       @default(0)
  lastStreakDate         DateTime?
  totalPracticeCompleted Int       @default(0)
  student                Student   @relation(fields: [studentId], references: [id])

  @@map("student_personalization_status")
}

model StudentPracticeSet {
  id          String            @id @default(uuid())
  studentId   String
  orgId       String
  name        String
  status      PracticeSetStatus @default(PENDING)
  questionIds String[]
  config      Json?
  expiresAt   DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  student     Student           @relation(fields: [studentId], references: [id])

  @@map("student_practice_sets")
}

model StudentStudyPlan {
  id            String                   @id @default(uuid())
  studentId     String                   @unique
  orgId         String
  dailyMins     Int
  durationDays  Int
  examDate      DateTime?
  startDate     DateTime                 @default(now())
  endDate       DateTime?
  planData      Json
  isActive      Boolean                  @default(true)
  adherencePct  Float                    @default(0)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  student       Student                  @relation(fields: [studentId], references: [id])
  dailyProgress StudyPlanDailyProgress[]

  @@map("student_study_plans")
}

model StudyPlanDailyProgress {
  id          String           @id @default(uuid())
  planId      String
  date        DateTime
  targetQs    Int
  completedQs Int              @default(0)
  isPassed    Boolean          @default(false)
  plan        StudentStudyPlan @relation(fields: [planId], references: [id])

  @@unique([planId, date])
  @@map("study_plan_daily_progress")
}

model ExtractFolder {
  id        String            @id @default(uuid())
  orgId     String
  name      String
  parentId  String?
  createdAt DateTime          @default(now())
  documents ExtractDocument[]

  @@map("extract_folders")
}

model ExtractDocument {
  id             String              @id @default(uuid())
  orgId          String
  folderId       String?
  fileName       String
  s3Key          String
  status         String              @default("PENDING")
  totalExtracted Int                 @default(0)
  creditsUsed    Float               @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  folder         ExtractFolder?      @relation(fields: [folderId], references: [id])
  questions      ExtractedQuestion[]

  @@map("extract_documents")
}

model ExtractedQuestion {
  id         String          @id @default(uuid())
  documentId String
  orgId      String
  textEn     String?
  textHi     String?
  options    Json?
  isCopied   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  document   ExtractDocument @relation(fields: [documentId], references: [id])

  @@map("extracted_questions")
}

model AttendanceRecord {
  id         String       @id @default(uuid())
  orgId      String
  studentId  String
  batchId    String?
  date       DateTime     @db.Date
  isPresent  Boolean
  markedById String?
  lockedAt   DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  markedBy   OrgStaff?    @relation("MarkedByStaff", fields: [markedById], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])
  student    Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, date, batchId])
  @@map("attendance_records")
}

model FeeStructure {
  id           String           @id @default(uuid())
  orgId        String
  name         String
  amount       Float
  dueDate      DateTime?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  org          Organization     @relation(fields: [orgId], references: [id])
  transactions FeeTransaction[]

  @@map("fee_structures")
}

model FeeTransaction {
  id             String         @id @default(uuid())
  orgId          String
  studentId      String
  feeStructureId String?
  amount         Float
  status         FeeStatus      @default(PENDING)
  paymentMethod  PaymentMethod?
  receiptNumber  String?
  notes          String?
  dueDate        DateTime?
  paidAt         DateTime?
  receiptUrl     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  feeStructure   FeeStructure?  @relation(fields: [feeStructureId], references: [id])
  org            Organization   @relation(fields: [orgId], references: [id])
  student        Student        @relation(fields: [studentId], references: [id])

  @@map("fee_transactions")
}

model OrgNotification {
  id             String              @id @default(uuid())
  orgId          String
  title          String
  body           String
  channel        NotificationChannel
  targetType     String
  targetIds      String[]            @default([])
  scheduledAt    DateTime?
  sentAt         DateTime?
  deliveredCount Int                 @default(0)
  failedCount    Int                 @default(0)
  createdAt      DateTime            @default(now())
  logs           NotificationLog[]
  org            Organization        @relation(fields: [orgId], references: [id])

  @@map("org_notifications")
}

model NotificationLog {
  id             String          @id @default(uuid())
  notificationId String
  recipientId    String
  recipientType  String
  isDelivered    Boolean         @default(false)
  failureReason  String?
  createdAt      DateTime        @default(now())
  notification   OrgNotification @relation(fields: [notificationId], references: [id])

  @@map("notification_logs")
}

model OrgPersonalizationSettings {
  id                  String       @id @default(uuid())
  orgId               String       @unique
  isEnabled           Boolean      @default(true)
  unlockThreshold     Int          @default(50)
  aiMatchEnabled      Boolean      @default(true)
  collabFilterEnabled Boolean      @default(false)
  studyPlanEnabled    Boolean      @default(true)
  updatedAt           DateTime     @updatedAt
  org                 Organization @relation(fields: [orgId], references: [id])

  @@map("org_personalization_settings")
}

model AdminCuratedSuggestion {
  id                  String       @id @default(uuid())
  orgId               String
  topicKeywords       String[]
  setId               String?
  folderId            String?
  title               String
  priority            Int          @default(0)
  expectedImprovement Float?
  impressions         Int          @default(0)
  attempts            Int          @default(0)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  org                 Organization @relation(fields: [orgId], references: [id])

  @@map("admin_curated_suggestions")
}

model StudyPlanTemplate {
  id           String       @id @default(uuid())
  orgId        String
  name         String
  description  String?
  durationDays Int
  templateData Json
  usageCount   Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id])

  @@map("study_plan_templates")
}

model AutoSetConfig {
  id         String       @id @default(uuid())
  orgId      String
  name       String
  configData Json
  schedules  Json?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  org        Organization @relation(fields: [orgId], references: [id])

  @@map("auto_set_configs")
}

model AiCreditTransaction {
  id          String       @id @default(uuid())
  orgId       String
  action      String
  credits     Float
  description String?
  createdAt   DateTime     @default(now())
  org         Organization @relation(fields: [orgId], references: [id])

  @@map("ai_credit_transactions")
}

model OrgAuditLog {
  id        String       @id @default(uuid())
  orgId     String
  actorId   String
  actorType String
  action    String
  resource  String?
  changes   Json?
  ip        String?
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@map("org_audit_logs")
}

model BulkUploadBatch {
  id                  String          @id @default(uuid())
  batchId             String          @unique
  orgId               String
  uploadFileName      String
  uploadFileType      String?
  totalRowsFound      Int             @default(0)
  totalQuestionsSaved Int             @default(0)
  totalFailedRows     Int             @default(0)
  uploadStatus        String          @default("Processing")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  org                 Organization    @relation(fields: [orgId], references: [id])
  rows                BulkUploadRow[]

  @@map("bulk_upload_batches")
}

model BulkUploadRow {
  id              String          @id @default(uuid())
  batchInternalId String
  rowNumber       Int
  rawQuestionText String?
  errorMessage    String?
  errorType       String?         @default("Validation Error")
  createdAt       DateTime        @default(now())
  batch           BulkUploadBatch @relation(fields: [batchInternalId], references: [id], onDelete: Cascade)

  @@map("bulk_upload_rows")
}

model ExamFolder {
  id          String         @id @default(uuid())
  name        String
  description String?
  icon        String?
  color       String?
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categories  ExamCategory[]

  @@map("exam_folders")
}

model ExamCategory {
  id            String            @id @default(uuid())
  folderId      String
  name          String
  description   String?
  icon          String?
  isActive      Boolean           @default(true)
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  folder        ExamFolder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  subCategories ExamSubCategory[]

  @@map("exam_categories")
}

model ExamSubCategory {
  id          String       @id @default(uuid())
  categoryId  String
  name        String
  description String?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    ExamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mockTests   MockTest[]

  @@map("exam_sub_categories")
}

model BlogAuthor {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  title           String?
  bio             String?
  photoUrl        String?
  email           String?
  linkedinUrl     String?
  twitterHandle   String?
  expertise       String?
  credentials     String?
  yearsExperience Int?
  role            String     @default("author")
  isActive        Boolean    @default(true)
  postCount       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  posts           BlogPost[]

  @@map("blog_authors")
}

model BlogCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  parentId    String?
  imageUrl    String?
  seoTitle    String?
  seoDesc     String?
  sortOrder   Int                @default(0)
  postCount   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  parent      BlogCategory?      @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    BlogCategory[]     @relation("CategoryHierarchy")
  posts       BlogPostCategory[]

  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  postCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  posts       BlogPostTag[]

  @@map("blog_tags")
}

model BlogPost {
  id                String             @id @default(cuid())
  title             String
  slug              String             @unique
  content           String?
  contentHtml       String?
  contentText       String?
  excerpt           String?
  featuredImageUrl  String?
  featuredImageAlt  String?
  coverImageUrl     String?
  contentType       String             @default("blog")
  status            String             @default("draft")
  visibility        String             @default("public")
  password          String?
  authorId          String
  seoTitle          String?
  seoDescription    String?
  focusKeyword      String?
  secondaryKeywords String?
  canonicalUrl      String?
  robotsIndex       Boolean            @default(true)
  robotsFollow      Boolean            @default(true)
  schemaType        String             @default("BlogPosting")
  sitemapPriority   Float              @default(0.8)
  sitemapChangefreq String             @default("weekly")
  ogTitle           String?
  ogDescription     String?
  ogImageUrl        String?
  twitterCard       String             @default("summary_large_image")
  viewCount         Int                @default(0)
  shareCount        Int                @default(0)
  commentCount      Int                @default(0)
  readingTimeMin    Int?
  wordCount         Int?
  allowComments     Boolean            @default(true)
  isFeatured        Boolean            @default(false)
  publishedAt       DateTime?
  scheduledAt       DateTime?
  unpublishAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  comments          BlogComment[]
  categories        BlogPostCategory[]
  tags              BlogPostTag[]
  author            BlogAuthor         @relation(fields: [authorId], references: [id])
  revisions         BlogRevision[]

  @@map("blog_posts")
}

model BlogPostCategory {
  postId     String
  categoryId String
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("blog_post_categories")
}

model BlogPostTag {
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model BlogComment {
  id          String        @id @default(cuid())
  postId      String
  parentId    String?
  authorName  String
  authorEmail String
  authorUrl   String?
  content     String
  status      String        @default("pending")
  ipAddress   String?
  userAgent   String?
  likeCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  parent      BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     BlogComment[] @relation("CommentReplies")
  post        BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("blog_comments")
}

model BlogRevision {
  id        String   @id @default(cuid())
  postId    String
  content   String?
  title     String?
  revisedBy String?
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("blog_revisions")
}

model BlogSetting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt

  @@map("blog_settings")
}

