# ===========================================
# EduHub Backend — Environment Variables
# Copy this to .env and fill in real values
# ===========================================

# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/eduhub_db"

# Redis
REDIS_URL="redis://localhost:6379"
# REDIS_URL="redis://:password@your-elasticache-endpoint:6379"  # Production

# JWT Secrets (use strong random strings in production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_SUPER_ADMIN_SECRET="your-super-admin-jwt-secret-change-this"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# AWS Configuration
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"

# S3 Bucket Names
AWS_S3_ASSETS_BUCKET="eduhub-assets-prod"
AWS_S3_PDFS_BUCKET="eduhub-pdfs-prod"
AWS_S3_RECEIPTS_BUCKET="eduhub-receipts-prod"
AWS_S3_EXPORTS_BUCKET="eduhub-exports-prod"
AWS_CLOUDFRONT_DOMAIN="your-cloudfront-domain.cloudfront.net"

# AWS SES (Email)
AWS_SES_FROM_EMAIL="noreply@eduhub.in"
AWS_SES_REGION="ap-south-1"

# OpenAI (for AI question generation, PDF extraction)
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# SMS (Msg91)
MSG91_API_KEY="your-msg91-api-key"
MSG91_SENDER_ID="EDUHUB"

# Razorpay (Optional — feature flag based)
RAZORPAY_KEY_ID="rzp_test_your-key"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# Firebase (for push notifications)
FCM_SERVER_KEY="your-fcm-server-key"

# CORS — allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,https://superadmin.eduhub.in,https://orgadmin.eduhub.in,https://eduhub.in"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
